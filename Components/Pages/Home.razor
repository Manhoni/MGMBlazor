@page "/"
@attribute [Authorize]
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using MGMBlazor.Domain.Entities
@using MGMBlazor.Infrastructure.Data
@using MGMBlazor.Infrastructure.Helpers
@using ApexCharts
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthProvider

<PageTitle>MGM - Início</PageTitle>

<div class="container-fluid mt-3 pb-5">
      <!-- CABEÇALHO BOAS-VINDAS -->
      <AuthorizeView>
            <div class="mb-4">
                  <h1 class="fw-bold text-mgm">Bem-vindo, @(context.User.FindFirst("NomeReal")?.Value ?? "Usuário")!</h1>
                  <p class="text-muted">Painel de controle e indicadores de faturamento.</p>
            </div>
      </AuthorizeView>

      <!-- FILTRO DE MÊS -->
      <div class="card p-2 mb-4 shadow-sm border-0 bg-light">
            <div class="d-flex align-items-center gap-3">
                  <label class="fw-bold small text-muted mb-0">VISUALIZAR MÊS DE:</label>
                  <select class="form-select form-select-sm shadow-sm w-auto" @bind="mesFiltro">
                  <option value="1">JANEIRO</option>
                  <option value="2">FEVEREIRO</option>
                  <option value="3">MARÇO</option>
                  <option value="4">ABRIL</option>
                  <option value="5">MAIO</option>
                  <option value="6">JUNHO</option>
                  <option value="7">JULHO</option>
                  <option value="8">AGOSTO</option>
                  <option value="9">SETEMBRO</option>
                  <option value="10">OUTUBRO</option>
                  <option value="11">NOVEMBRO</option>
                  <option value="12">DEZEMBRO</option>
                  </select>
                  <button class="btn btn-sm btn-dark px-4" @onclick="CarregarDadosDashboard">
                  <i class="bi bi-arrow-clockwise"></i> ATUALIZAR
                  </button>
            </div>
      </div>

      <!-- TABS -->
        <AuthorizeView Roles="Admin">
            <ul class="nav nav-pills mb-4 p-1 bg-white shadow-sm rounded-pill w-auto d-inline-flex border">
                  <li class="nav-item">
                        <button class="nav-link @(abaAtiva == 1 ? "active" : "") rounded-pill px-4" @onclick="() => abaAtiva = 1">Operacional</button>
                  </li>
                  <li class="nav-item">
                        <button class="nav-link @(abaAtiva == 2 ? "active" : "") rounded-pill px-4" @onclick="() => abaAtiva = 2">Performance</button>
                  </li>
            </ul>
        </AuthorizeView>
     

    @if (abaAtiva == 1)
    {
        <!-- CARDS DE RESUMO (TOPO) -->
        <div class="row g-3 mb-4">
            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 bg-mgm-verde">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <div>
                                <p class="small mb-1 text-white opacity-75 fw-bold">TOTAL FATURADO</p>
                                <h3 class="fw-bold mb-0 text-white">@totalFaturadoMes.ToString("C2")</h3>
                            </div>
                            <i class="bi bi-currency-dollar fs-1 text-white opacity-25"></i>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 bg-white border-left-mgm">
                    <div class="card-body d-flex justify-content-between">
                        <div>
                            <p class="small mb-1 text-muted fw-bold">NOTAS EMITIDAS</p>
                            <h3 class="fw-bold text-dark mb-0">@qtdNotasMes</h3>
                        </div>
                        <i class="bi bi-file-earmark-check fs-2 text-success opacity-25"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <div class="card h-100 border-0 shadow-sm rounded-4 bg-white border-left-warning text-dark">
                    <div class="card-body d-flex justify-content-between">
                        <div>
                            <p class="small mb-1 text-muted fw-bold">A RECEBER (MÊS)</p>
                            <h3 class="fw-bold mb-0">@totalPendenteMes.ToString("C2")</h3>
                        </div>
                        <i class="bi bi-calendar-event fs-2 text-warning opacity-25"></i>
                    </div>
                </div>
            </div>

            <div class="col-md-3">
                <button class="btn btn-primary w-100 h-100 rounded-4 shadow p-3 d-flex flex-column align-items-center justify-content-center"
                        @onclick='() => Nav.NavigateTo("/faturamento")'>
                    <i class="bi bi-plus-circle fs-3 mb-1"></i>
                    <span class="fw-bold small">NOVO FATURAMENTO</span>
                </button>
            </div>
        </div>

        <!-- SEGUNDA LINHA: GRÁFICO E MINI-CARDS DE COBRANÇA -->
        <div class="row g-3 mb-4">
            <!-- GRÁFICO (9 colunas para dar mais espaço) -->
            <div class="col-md-9">
                <div class="card border-0 shadow-sm rounded-4 p-4 h-100 chart-box">
                    <h6 class="fw-bold text-dark mb-3 small text-uppercase"><i class="bi bi-bar-chart"></i> Evolução de Faturamento</h6>
                    <div style="height: 300px; width: 100%;">
                        <ApexChart TItem="DadosGrafico" Title="" Options="optionsGrafico" Height="400">
                            <ApexPointSeries TItem="DadosGrafico" Items="dadosFaturamento" Name="Faturado" 
                                            SeriesType="SeriesType.Bar" XValue="@(e => e.MesNome)" YValue="@(e => e.Valor)"
                                            Color="#76b82a" />
                        </ApexChart>
                    </div>
                </div>
            </div>

            <!-- DETALHES DE COBRANÇA (3 colunas) -->
            <div class="col-md-3">
                <div class="d-flex flex-column gap-3 h-100">
                    <div class="card border-0 shadow-sm rounded-4 bg-white border-left-danger flex-fill">
                        <div class="card-body d-flex flex-column justify-content-center text-center">
                            <div class="mb-2"><i class="bi bi-exclamation-octagon text-danger fs-3"></i></div>
                            <span class="text-danger fw-bold small">INADIMPLÊNCIA TOTAL</span>
                            <h2 class="fw-bold text-danger mb-0">@totalAtrasadoGeral.ToString("C2")</h2>
                            <small class="text-muted">Boletos vencidos (Geral)</small>
                        </div>
                    </div>
                    <div class="card border-0 shadow-sm rounded-4 bg-white border-left-receber flex-fill">
                        <div class="card-body d-flex flex-column justify-content-center text-center">
                            <div class="mb-2"><i class="bi bi-clock-history text-receber fs-3"></i></div>
                            <span class="text-receber fw-bold small">A VENCER (MÊS)</span>
                            <h2 class="fw-bold text-receber mb-0">@totalAVencerMes.ToString("C2")</h2>
                            <small class="text-muted">Provisão de recebimento</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- TERCEIRA LINHA: LOGS (Só Admin) -->
        <div class="row justify-content-end">
            <div class="col-md-4">
                <AuthorizeView Roles="Admin">
                    <div class="card border-0 shadow-sm rounded-4 bg-white overflow-hidden">
                        <div class="card-header bg-white border-0 py-2">
                            <h6 class="m-0 fw-bold text-muted small text-uppercase">Atividade Recente</h6>
                        </div>
                        <div class="card-body p-0" style="max-height: 200px; overflow-y: auto;">
                            <div class="list-group list-group-flush">
                                @foreach (var log in ultimosLogs)
                                {
                                    <div class="list-group-item border-0 py-1 bg-transparent" style="font-size: 0.7rem;">
                                        <div class="d-flex justify-content-between">
                                            <span class="fw-bold text-mgm">@log.Operacao.ToUpper()</span>
                                            <span class="text-muted" style="font-size: 0.6rem;">@MGMFormatador.ParaHoraLocal(log.DataHora)</span>
                                        </div>
                                        <div class="text-dark text-truncate" title="@log.Detalhes">
                                            @log.Detalhes
                                        </div>
                                        <div class="text-muted italic mt-1" style="font-size: 0.65rem;">
                                            <i class="bi bi-person-circle"></i> @(log.Usuario.Contains("@") ? log.Usuario.Split('@')[0] : log.Usuario)
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </AuthorizeView>
            </div>
        </div>
    }
    else
    {
        <!-- ABA PERFORMANCE (Dono) -->
        <div class="row g-3">
            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white h-100">
                    <div class="icon-circle"> 
                        <i class="bi bi-lightning-charge fs-2 text-success"></i>
                    </div>
                    <h2 class="fw-bold text-dark mt-2">@horasEconomizadas.ToString("N1")h</h2>
                    <p class="text-muted mb-0">Tempo economizado este mês</p>
                    <small class="text-success fw-bold">Comparado ao processo manual</small>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white h-100">
                    <div class="icon-circle">
                        <i class="bi bi-shield-x fs-1 text-danger"></i>
                    </div>
                    <h2 class="fw-bold text-dark">@percentualCancelamento.ToString("N1")%</h2>
                    <p class="text-muted mb-0">Índice de Cancelamento</p>
                    <small class="text-muted small">Total de notas falhas ou anuladas</small>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card border-0 shadow-sm rounded-4 p-4 text-center bg-white h-100">
                    <div class="icon-circle">
                        <i class="bi bi-people fs-1 text-info"></i>
                    </div>
                    <h2 class="fw-bold text-dark">@qtdClientesAtendidos</h2>
                    <p class="text-muted mb-0">Clientes Atendidos</p>
                    <small class="text-muted small">CNPJs únicos faturados no mês</small>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private decimal totalFaturadoMes;
    private int qtdNotasMes;
    //private decimal totalPendente;
    private List<LogAuditoria> ultimosLogs = new();
    private int abaAtiva = 1;
    private int mesFiltro = DateTime.Today.Month;
    private List<DadosGrafico> dadosFaturamento = new();
    private ApexChartOptions<DadosGrafico> optionsGrafico = new();

    private double horasEconomizadas;
    private double percentualCancelamento;
    private int qtdClientesAtendidos;
    private decimal totalAtrasadoGeral; 
    private decimal totalAVencerMes;   
    private decimal totalPendenteMes;

    protected override async Task OnInitializedAsync()
    {
        ConfigurarGrafico();
        await CarregarDadosDashboard();
    }

    private void ConfigurarGrafico()
    {
        optionsGrafico = new ApexChartOptions<DadosGrafico> {
            Chart = new Chart { 
                Toolbar = new Toolbar { Show = false }, 
                Zoom = new Zoom { Enabled = false } 
            },
            Legend = new Legend { Show = false }, // REMOVE O TEXTO NO RODAPÉ
            DataLabels = new DataLabels { Enabled = true }, // REMOVE NÚMEROS EM CIMA DAS BARRAS
            Xaxis = new XAxis { 
                Labels = new XAxisLabels { Style = new AxisLabelStyle { FontSize = "10px" } } 
            }
        };
    }

    private async Task CarregarDadosDashboard()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        
        // Ajuste de fuso para Maringá
        var anoAtual = DateTime.UtcNow.AddHours(-3).Year;

        // 1. Resumo Operacional
        totalFaturadoMes = await context.NotasFiscaisEmitidas
            .Where(n => n.DataEmissao.Month == mesFiltro && n.DataEmissao.Year == anoAtual && n.Status == StatusNfse.Faturada)
            .SumAsync(n => n.Valor);

        qtdNotasMes = await context.NotasFiscaisEmitidas
            .CountAsync(n => n.DataEmissao.Month == mesFiltro && n.DataEmissao.Year == anoAtual && n.Status == StatusNfse.Faturada);

        // Parte relacioada aos boletos e cobranças
        var hoje = DateTime.Today;

        // 1. Tudo o que está em aberto e o vencimento é MENOR que hoje (Inadimplência total)
        totalAtrasadoGeral = await context.Cobrancas
            .Where(c => (c.Status == "Em Aberto" || c.Status == "Pendente") && c.DataVencimento.Date < hoje)
            .SumAsync(c => c.Valor);

        // 2. O que vence no mês selecionado, no ano atual e ainda não venceu (ou vence hoje)
        totalAVencerMes = await context.Cobrancas
            .Where(c => (c.Status == "Em Aberto" || c.Status == "Pendente") 
                    && c.DataVencimento.Year == anoAtual 
                    && c.DataVencimento.Month == mesFiltro
                    && c.DataVencimento.Date >= hoje)
            .SumAsync(c => c.Valor);

        // 3. O Total que o usuário espera receber no mês selecionado
        totalPendenteMes = totalAVencerMes + await context.Cobrancas
            .Where(c => (c.Status == "Em Aberto" || c.Status == "Pendente") 
                    && c.DataVencimento.Year == anoAtual 
                    && c.DataVencimento.Month == mesFiltro
                    && c.DataVencimento.Date < hoje)
            .SumAsync(c => c.Valor);

        // 2. Dados da Aba de Performance
        var totalEmitidas = await context.NotasFiscaisEmitidas
            .CountAsync(n => n.DataEmissao.Month == mesFiltro && n.DataEmissao.Year == anoAtual);
        
        var totalCanceladas = await context.NotasFiscaisEmitidas
            .CountAsync(n => n.DataEmissao.Month == mesFiltro && n.DataEmissao.Year == anoAtual && n.Status == StatusNfse.Cancelada);

        horasEconomizadas = (qtdNotasMes * 19.0) / 60.0;
        percentualCancelamento = totalEmitidas > 0 ? (totalCanceladas * 100.0 / totalEmitidas) : 0;
        
        qtdClientesAtendidos = await context.NotasFiscaisEmitidas
            .Where(n => n.DataEmissao.Month == mesFiltro && n.DataEmissao.Year == anoAtual && n.Status == StatusNfse.Faturada)
            .Select(n => n.CnpjTomador)
            .Distinct()
            .CountAsync();

        // 3. Gráfico de Evolução (Últimos 6 Meses)
        var dataLimite = DateTime.UtcNow.AddHours(-3).AddMonths(-5);
        var dadosBrutos = await context.NotasFiscaisEmitidas
            .Where(n => n.DataEmissao >= dataLimite && n.Status == StatusNfse.Faturada)
            .GroupBy(n => new { n.DataEmissao.Year, n.DataEmissao.Month })
            .Select(g => new { g.Key.Year, g.Key.Month, Total = g.Sum(x => x.Valor) })
            .ToListAsync();

        dadosFaturamento = dadosBrutos
            .OrderBy(d => d.Year).ThenBy(d => d.Month)
            .Select(d => new DadosGrafico { 
                MesNome = System.Globalization.DateTimeFormatInfo.CurrentInfo.GetAbbreviatedMonthName(d.Month).ToUpper(),
                Valor = d.Total 
            }).ToList();

        // 4. Logs Audit (Compactos)
        ultimosLogs = await context.LogsAuditoria
            .OrderByDescending(l => l.DataHora)
            .Take(10)
            .ToListAsync();

        StateHasChanged();
    }

    public class DadosGrafico { public string MesNome { get; set; } = ""; public decimal Valor { get; set; } }
}