@rendermode InteractiveServer
@using MGMBlazor.web.Components.Layout

<footer class="footer mt-auto">
    <div class="container-fluid text-center">
        <span class="text-muted small">
            Desenvolvido por <strong>João Gabriel Manhoni</strong> |
            MGM Engenharia - Sistema de Faturamento |
            <span class="badge bg-secondary" 
                  @onclick="ToggleChangelog" 
                  style="cursor: pointer;" 
                  title="Ver novidades">v0.9.7</span>
        </span>
    </div>
</footer>

@if (mostrarChangelog)
{
    <div class="changelog-overlay" @onclick="ToggleChangelog">
        <div class="changelog-modal shadow-lg" @onclick:stopPropagation>
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h4 class="m-0 text-success fw-bold">Histórico de Atualizações</h4>
                <button class="btn-close" @onclick="ToggleChangelog"></button>
            </div>
            
            <Changelog />
            
            <div class="text-center mt-4">
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleChangelog">Fechar</button>
            </div>
        </div>
    </div>
}

@code {
    private bool mostrarChangelog = false;
    private void ToggleChangelog() => mostrarChangelog = !mostrarChangelog;
}